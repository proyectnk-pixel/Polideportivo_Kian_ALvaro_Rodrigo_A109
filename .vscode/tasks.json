{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar Proyecto GTK3",
            "type": "shell",
            "command": "gcc src/*.c -o ${workspaceFolder}/polideportivo.exe (-split (pkg-config --cflags --libs gtk+-3.0 gmodule-export-2.0))",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}